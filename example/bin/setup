#!/usr/bin/env ruby
system("bundle", "install", exception: true)
system("docker", "compose", "up", "-d", exception: true)
sleep 2 # wait for postgres
system("bundle", "exec", "rails", "db:prepare", exception: true)
system("bundle", "exec", "rails", "db:seed", exception: true)
puts "\nSetup complete. Run bin/dev to start the server."
