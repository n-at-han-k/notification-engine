<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Notification Engine Example" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag "notification_engine/application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav style="padding: 0.75rem 1rem; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center;">
      <%= link_to "Home", main_app.root_path %>
      <%= notification_bell %>
    </nav>

    <main style="padding: 1rem;">
      <%= yield %>
    </main>
  </body>
</html>
