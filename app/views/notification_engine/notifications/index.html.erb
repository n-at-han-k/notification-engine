<div class="notification-engine" id="notification-engine">
  <div class="notification-header">
    <h2>Notifications</h2>

    <div class="notification-actions">
      <div class="notification-filters">
        <%= link_to "All", notifications_path, class: "filter-link #{active_filter_class(nil)}" %>
        <%= link_to "Unread", notifications_path(filter: "unread"), class: "filter-link #{active_filter_class('unread')}" %>
        <%= link_to "Read", notifications_path(filter: "read"), class: "filter-link #{active_filter_class('read')}" %>
      </div>

      <%= button_to "Mark all as read", mark_all_read_notifications_path, method: :post, class: "mark-all-read-btn" %>
    </div>
  </div>

  <%= render partial: "notification_engine/notifications/list", locals: { notifications: @notifications } %>
</div>
