<div id="notifications">
  <% if notifications.any? %>
    <% notifications.each do |notification| %>
      <%= render partial: "notification_engine/notifications/notification", locals: { notification: notification } %>
    <% end %>
  <% else %>
    <div class="notification-empty">
      <p>All caught up!</p>
    </div>
  <% end %>
</div>
